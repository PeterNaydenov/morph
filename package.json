{
    "name": "@peter.naydenov/morph",
    "description": "Template engine",
    "version": "3.4.4",
    "license": "MIT",
    "author": "Peter Naydenov",
    "main": "./src/main.js",
    "type": "module",
    "types": "./dist/main.d.ts",
    "exports": {
        ".": {
            "import": "./src/main.js",
            "require": "./dist/morph.cjs",
            "default": "./src/main.js"
        },
        "./package.json": "./package.json",
        "./dist/*": "./dist/*",
        "./src/*": "./src/*"
    },
    "scripts": {
        "test": "vitest run",
        "cover": "vitest run --coverage",
        "build": "npm run build:types && rollup -c",
        "build:types": "tsc"
    },
    "dependencies": {
        "@peter.naydenov/stack": "^3.0.0",
        "@peter.naydenov/walk": "^5.0.6"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@vitest/coverage-v8": "^4.0.0",
        "rollup": "^4.62.2",
        "typescript": "^7.0.2",
        "vitest": "^4.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PeterNaydenov/morph.git"
    },
    "vitest": {
        "coverage": {
            "include": [
                "src/**/*.js"
            ],
            "exclude": [
                "node_modules",
                "test"
            ],
            "reporter": [
                "lcov",
                "text-summary"
            ]
        }
    },
    "keywords": [
        "template",
        "engine",
        "string",
        "function"
    ],
    "engines": {
        "node": ">=18"
    },
    "allowScripts": {
        "fsevents@2.3.3": true
    }
}
